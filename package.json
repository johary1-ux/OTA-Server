{
  "name": "beautybay-ota-server",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone Expo Updates v1 OTA server for the BeautyBay mobile app",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:fresh": "node scripts/kill-port.mjs && tsx watch src/index.ts",
    "kill-port": "node scripts/kill-port.mjs",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ota:publish:dev": "bash scripts/publish-sample.sh development",
    "ota:publish:staging": "bash scripts/publish-sample.sh staging",
    "ota:publish:production": "bash scripts/publish-sample.sh production"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "form-data": "^4.0.1",
    "helmet": "^8.0.0",
    "multer": "^2.0.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "pino-roll": "^2.0.0",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.1",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
