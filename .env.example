# Server
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Storage roots (Windows: use full paths with backslashes escaped or forward slashes)
OTA_BUNDLES_PATH=C:\OTA\bundles
OTA_LOGS_PATH=C:\OTA\logs
OTA_UPLOADS_TMP=C:\OTA\tmp

# Auth: generate with `openssl rand -hex 32`
OTA_PUBLISH_KEY=change-me-to-a-32-plus-char-random-secret

# Public base URL used to build asset URLs in the manifest
# (must match the Cloudflare Tunnel hostname seen by the mobile app)
OTA_PUBLIC_BASE_URL=https://ota.beautybay.example.com

# Comma-separated allowed CORS origins (Cloudflare Tunnel hosts, dashboards, etc.)
OTA_CORS_ORIGINS=https://ota.beautybay.example.com

# Rate limiting on /api/publish
OTA_PUBLISH_RATE_WINDOW_MS=60000
OTA_PUBLISH_RATE_MAX=10
